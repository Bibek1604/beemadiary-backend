datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum UserType {
  ADMIN
  AGENT
  CLIENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PolicyStatus {
  ACTIVE
  LAPSED
  EXPIRED
  PENDING
}

enum NotificationTargetType {
  SINGLE
  ALL
}

enum TransactionType {
  PREMIUM_PAYMENT
  CLAIM_PAYOUT
  COMMISSION
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model Admin {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique
  email         String    @unique
  phone         String    @unique
  password_hash String
  role          Role      @default(ADMIN)
  status        Status    @default(ACTIVE)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  bulk_notifications BulkNotification[]

  @@map("admins")
}

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  phone_number String    @unique
  image        String
  address      String?
  status       Status    @default(ACTIVE)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("companies")
}

model Agent {
  id                        String    @id @default(uuid()) @db.Uuid
  agent_code                String?   @unique
  full_name                 String
  email                     String    @unique
  phone_number              String    @unique
  password_hash             String
  lic_agent_code            String?   @unique
  branch_division           String?
  qualification             String?
  position_designation      String?
  short_bio                 String?
  profile_picture           String?
  profile_picture_public_id String?
  status                    Status    @default(ACTIVE)
  company_id                String?   @db.Uuid
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  clients              Client[]
  bulk_notifications   BulkNotification[]
  notification_reads   NotificationRead[]

  @@map("agents")
}

model Client {
  id            String    @id @default(uuid()) @db.Uuid
  first_name    String
  last_name     String
  email         String    @unique
  phone         String    @unique
  password_hash String?
  address       String
  status        Status    @default(ACTIVE)
  agent_id      String    @db.Uuid
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  agent Agent @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@map("clients")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  user_type  UserType
  token      String    @unique
  expires_at DateTime
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("sessions")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  user_type  UserType?
  action     String
  details    Json?
  ip_address String?
  created_at DateTime  @default(now())

  @@map("audit_logs")
}

model Policy {
  id            String       @id @default(uuid()) @db.Uuid
  policy_number String       @unique
  name          String
  type          String
  status        PolicyStatus @default(PENDING)
  client_id     String       @db.Uuid
  agent_id      String       @db.Uuid
  company_id    String       @db.Uuid
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  deleted_at    DateTime?

  @@map("policies")
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  policy_id        String            @db.Uuid
  amount           Decimal           @db.Decimal(12, 2)
  type             TransactionType
  payment_method   String
  status           TransactionStatus @default(PENDING)
  reference_number String?           @unique
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  deleted_at       DateTime?

  @@map("transactions")
}

model Notification {
  id                  String    @id @default(uuid()) @db.Uuid
  recipient_id        String    @db.Uuid
  recipient_type      UserType
  title               String
  message             String
  is_read             Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@map("notifications")
}

model BulkNotification {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  content         String
  target_type     NotificationTargetType
  target_agent_id String?  @db.Uuid
  created_by      String   @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  target_agent Agent?     @relation(fields: [target_agent_id], references: [id], onDelete: SetNull)
  creator      Admin      @relation(fields: [created_by], references: [id], onDelete: Cascade)
  reads        NotificationRead[]

  @@map("bulk_notifications")
}

model NotificationRead {
  id              String   @id @default(uuid()) @db.Uuid
  notification_id String   @db.Uuid
  agent_id        String   @db.Uuid
  is_read         Boolean  @default(false)
  read_at         DateTime?
  created_at      DateTime @default(now())

  agent      Agent          @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  notification BulkNotification @relation(fields: [notification_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, agent_id])
  @@map("notification_reads")
}