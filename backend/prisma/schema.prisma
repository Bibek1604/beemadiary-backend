datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum UserType {
  ADMIN
  AGENT
  CLIENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PolicyStatus {
  ACTIVE
  LAPSED
  EXPIRED
  PENDING
}

enum NotificationTargetType {
  SINGLE
  ALL
}

enum TransactionType {
  PREMIUM_PAYMENT
  CLAIM_PAYOUT
  COMMISSION
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model Admin {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique
  email         String    @unique
  phone         String    @unique
  password_hash String
  role          Role      @default(ADMIN)
  status        Status    @default(ACTIVE)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  bulk_notifications BulkNotification[]

  @@map("admins")
}

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  phone_number String    @unique
  image        String
  address      String?
  status       Status    @default(ACTIVE)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  @@map("companies")
}

model Agent {
  id                        String    @id @default(uuid()) @db.Uuid
  agent_code                String?   @unique
  full_name                 String
  email                     String    @unique
  phone_number              String    @unique
  password_hash             String
  lic_agent_code            String?   @unique
  branch_division           String?
  qualification             String?
  position_designation      String?
  short_bio                 String?
  profile_picture           String?
  profile_picture_public_id String?
  security_pin              String?
  status                    Status    @default(ACTIVE)
  company_id                String?   @db.Uuid
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  clients              Client[]
  bulk_notifications   BulkNotification[]
  notification_reads   NotificationRead[]
  events               Event[]
  personal_notes       PersonalNote[]

  @@map("agents")
}

model Client {
  id                        String    @id @default(uuid()) @db.Uuid
  client_id                 String?   @unique  // Enrollment ID for searching
  first_name                String
  last_name                 String
  email                     String    @unique
  phone                     String    @unique
  secondary_phone           String?
  password_hash             String?
  address                   String
  dob                       DateTime?
  age                       Int?
  gender                    String?
  nominee_name              String?
  relation_with_nominee     String?
  profession                String?
  member_group              String?
  reason_for_insurance      String?
  profile_picture           String?
  profile_picture_public_id String?
  image1                    String?
  image1_public_id          String?
  image2                    String?
  image2_public_id          String?
  security_pin              String?
  status                    Status    @default(ACTIVE)
  agent_id                  String    @db.Uuid
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  agent    Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  policies Policy[]

  @@map("clients")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  user_type  UserType
  token      String    @unique
  expires_at DateTime
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("sessions")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  user_type  UserType?
  action     String
  details    Json?
  ip_address String?
  created_at DateTime  @default(now())

  @@map("audit_logs")
}

model Policy {
  id                String       @id @default(uuid())
  policy_number     String       @unique
  plan_name         String
  plan_no           String
  policy_term       String?      // Premium Term (e.g., "10 years")
  sum_assured        Decimal?     @db.Decimal(15, 2)
  ab_pwb            String?      // Additional Benefit / Partial Withdrawal Benefit
  doc               String?      // Date of Commencement (AD/BS)
  maturity_time     DateTime?
  premium_amount    Decimal?     @db.Decimal(12, 2)
  discount_scheme   String?
  premium_due_date  String?      // AD/BS format
  bank_name         String?
  bank_account      String?
  branch            String?
  premium_paid      Decimal?     @db.Decimal(12, 2)
  status            PolicyStatus @default(PENDING)
  client_id         String       @db.Uuid
  agent_id          String       @db.Uuid
  company_id        String?      @db.Uuid
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  deleted_at        DateTime?

  client       Client        @relation(fields: [client_id], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("policies")
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  policy_id        String            @db.Uuid
  amount           Decimal           @db.Decimal(12, 2)
  type             TransactionType
  payment_method   String
  status           TransactionStatus @default(PENDING)
  reference_number String?           @unique
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  deleted_at       DateTime?

  policy           Policy            @relation(fields: [policy_id], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Notification {
  id                  String    @id @default(uuid()) @db.Uuid
  recipient_id        String    @db.Uuid
  recipient_type      UserType
  title               String
  message             String
  is_read             Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@map("notifications")
}

model BulkNotification {
  id              String   @id @default(uuid()) @db.Uuid
  title           String
  content         String
  target_type     NotificationTargetType
  target_agent_id String?  @db.Uuid
  created_by      String   @db.Uuid
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  deleted_at      DateTime?

  target_agent Agent?     @relation(fields: [target_agent_id], references: [id], onDelete: SetNull)
  creator      Admin      @relation(fields: [created_by], references: [id], onDelete: Cascade)
  reads        NotificationRead[]

  @@map("bulk_notifications")
}

model NotificationRead {
  id              String   @id @default(uuid()) @db.Uuid
  notification_id String   @db.Uuid
  agent_id        String   @db.Uuid
  is_read         Boolean  @default(false)
  read_at         DateTime?
  created_at      DateTime @default(now())

  agent      Agent          @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  notification BulkNotification @relation(fields: [notification_id], references: [id], onDelete: Cascade)

  @@unique([notification_id, agent_id])
  @@map("notification_reads")
}

model Event {
  id                   String    @id @default(uuid()) @db.Uuid
  title                String
  description          String?   @db.Text
  event_type           String    @default("OTHER") // MEETING, FOLLOW_UP, RENEWAL, PREMIUM, PERSONAL, OTHER
  event_date           DateTime
  event_time           String?   // HH:MM format
  is_all_day           Boolean   @default(false)
  location             String?
  color_label          String    @default("indigo")
  is_recurring         Boolean   @default(false)
  recurrence_pattern   String?   // DAILY, WEEKLY, MONTHLY, YEARLY
  recurrence_end_date  DateTime?
  parent_event_id      String?   @db.Uuid
  reminder_minutes     Int?
  agent_id             String    @db.Uuid
  client_id            String?   @db.Uuid
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  deleted_at           DateTime?

  agent   Agent   @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@index([agent_id])
  @@index([event_date])
  @@index([deleted_at])
  @@map("events")
}

model PersonalNote {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  content         String    @db.Text
  category        String?   // GENERAL, REMINDER, FOLLOW_UP, etc.
  color_label     String    @default("indigo")
  is_pinned       Boolean   @default(false)
  agent_id        String    @db.Uuid
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleted_at      DateTime?

  agent   Agent   @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@index([agent_id])
  @@index([deleted_at])
  @@map("personal_notes")
}