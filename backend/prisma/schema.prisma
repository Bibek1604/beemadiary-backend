generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int       @id @default(autoincrement())
  email                 String    @unique
  password              String
  password_hash         String?
  first_name            String
  last_name             String
  role                  UserRole  @default(AGENT)
  is_active             Boolean   @default(true)
  email_verified        Boolean   @default(false)
  email_verified_at     DateTime?
  twofa_enabled         Boolean   @default(false)
  last_login            DateTime?
  last_login_ip         String?
  login_attempt_count   Int       @default(0)
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  agents                Agent?
  notifications         Notification[]
  sessions              Session[]
  refresh_tokens        RefreshToken[]
  audit_logs            AuditLog[]
  account_lockout       AccountLockout?
  password_resets       PasswordReset[]
  email_verifications   EmailVerification[]
  twofa_auth            TwoFactorAuth?

  @@index([email])
  @@index([role])
  @@index([is_active])
  @@index([created_at])
}

enum UserRole {
  ADMIN
  AGENT
  USER
}

model Agent {
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  agent_code      String    @unique
  total_clients   Int       @default(0)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  clients         Client[]
  targets         Target[]
  
  @@index([user_id])
  @@index([agent_code])
}

model Client {
  id              Int       @id @default(autoincrement())
  agent_id        Int
  first_name      String
  last_name       String
  email           String?
  contact_number  String
  dob             DateTime
  gender          Gender    @default(OTHER)
  address         String?
  city            String?
  state           String?
  postal_code     String?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  agent           Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  policies        ClientPolicy[]
  alerts          Alert[]
  
  @@index([agent_id])
  @@index([dob])
  @@index([is_active])
}

enum Gender {
  MALE
  FEMALE
  CHILD
  OTHER
}

model Policy {
  id              Int       @id @default(autoincrement())
  policy_code     String    @unique
  policy_name     String
  base_premium    Decimal   @db.Numeric(10, 2)
  description     String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  client_policies ClientPolicy[]
  
  @@index([policy_code])
}

model ClientPolicy {
  id                  Int       @id @default(autoincrement())
  client_id           Int
  policy_id           Int
  policy_number       String    @unique
  premium_amount      Decimal   @db.Numeric(10, 2)
  premium_due_date    DateTime
  premium_due_paid    PremiumStatus @default(DUE)
  last_premium_paid   DateTime?
  policy_status       PolicyStatus @default(ACTIVE)
  why_bought          WhyBoughtReason @default(PROTECTION)
  commencement_date   DateTime
  maturity_date       DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  
  client              Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  policy              Policy    @relation(fields: [policy_id], references: [id], onDelete: Restrict)
  payments            Payment[]
  
  @@index([client_id])
  @@index([policy_id])
  @@index([premium_due_date])
  @@index([policy_status])
  @@index([why_bought])
}

enum PremiumStatus {
  DUE
  PAID
  OVERDUE
}

enum PolicyStatus {
  ACTIVE
  INACTIVE
  LAPSED
  MATURED
  SURRENDERED
}

enum WhyBoughtReason {
  PROTECTION
  INVESTMENT
  TAX_SAVING
  CHILD_EDUCATION
  RETIREMENT
  WEALTH_CREATION
  OTHER
}

model Payment {
  id                Int       @id @default(autoincrement())
  client_policy_id  Int
  payment_amount    Decimal   @db.Numeric(10, 2)
  payment_date      DateTime  @default(now())
  payment_mode      String
  receipt_number    String?   @unique
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  
  client_policy     ClientPolicy @relation(fields: [client_policy_id], references: [id], onDelete: Cascade)
  
  @@index([client_policy_id])
  @@index([payment_date])
}

model Notification {
  id              Int       @id @default(autoincrement())
  user_id         Int
  title           String
  message         String
  notification_type NotificationType @default(INFO)
  is_read         Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@index([user_id])
  @@index([is_read])
  @@index([created_at])
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  REMINDER
}

model Alert {
  id              Int       @id @default(autoincrement())
  client_id       Int
  alert_type      AlertType
  alert_message   String
  severity        AlertSeverity @default(MEDIUM)
  is_resolved     Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  client          Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  
  @@index([client_id])
  @@index([is_resolved])
  @@index([created_at])
  @@index([alert_type])
}

enum AlertType {
  PREMIUM_OVERDUE
  POLICY_LAPSED
  BIRTHDAY_REMINDER
  MATURITY_APPROACHING
  DOCUMENT_EXPIRY
  ANNIVERSARY
  CUSTOM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Target {
  id              Int       @id @default(autoincrement())
  agent_id        Int
  target_month    DateTime
  target_type     TargetType
  target_value    Decimal   @db.Numeric(10, 2)
  current_value   Decimal   @db.Numeric(10, 2) @default(0)
  target_unit     String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  
  agent           Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  
  @@index([agent_id])
  @@index([target_month])
  @@unique([agent_id, target_month, target_type])
}

enum TargetType {
  NEW_POLICIES
  PREMIUM_COLLECTION
  CLIENT_ACQUISITION
  POLICY_RENEWAL
}

model Achievement {
  id              Int       @id @default(autoincrement())
  title           String
  description     String?
  icon_url        String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
}

// ==================== AUTHENTICATION MODELS ====================

model Session {
  id                    String    @id @default(cuid())
  user_id               Int
  device_name           String?
  user_agent            String?
  ip_address            String
  expires_at            DateTime
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  last_activity         DateTime  @default(now())
  is_active             Boolean   @default(true)

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_active])
  @@index([expires_at])
  @@index([created_at])
}

model RefreshToken {
  id                    String    @id @default(cuid())
  user_id               Int
  token_hash            String    @unique
  family_id             String?
  parent_token_hash     String?
  expires_at            DateTime
  revoked_at            DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  device_name           String?
  ip_address            String?

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([family_id])
  @@index([expires_at])
  @@index([created_at])
}

model AuditLog {
  id                    String    @id @default(cuid())
  user_id               Int
  action                String
  resource              String
  resource_id           String?
  old_value             String?
  new_value             String?
  ip_address            String?
  user_agent            String?
  status                AuditStatus @default(SUCCESS)
  error_message         String?
  created_at            DateTime  @default(now())

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([action])
  @@index([resource])
  @@index([created_at])
}

enum AuditStatus {
  SUCCESS
  FAILURE
  ATTEMPT
}

model AccountLockout {
  id                    String    @id @default(cuid())
  user_id               Int       @unique
  failed_attempts       Int       @default(0)
  locked_until          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([locked_until])
}

model PasswordReset {
  id                    String    @id @default(cuid())
  user_id               Int
  token_hash            String    @unique
  expires_at            DateTime
  used_at               DateTime?
  created_at            DateTime  @default(now())

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model EmailVerification {
  id                    String    @id @default(cuid())
  user_id               Int
  email                 String
  token_hash            String    @unique
  expires_at            DateTime
  verified_at           DateTime?
  created_at            DateTime  @default(now())

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([email])
  @@index([expires_at])
}

model TwoFactorAuth {
  id                    String    @id @default(cuid())
  user_id               Int       @unique
  secret                String
  backup_codes          String[]
  verified_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}
