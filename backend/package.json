{
  "name": "dashboard-overview-api",
  "version": "1.0.0",
  "description": "Production-level Dashboard Overview API with Advanced Analytics",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node --transpile-only src/server.ts",
    "build": "tsc --noCheck",
    "start": "node dist/server.js",
    "start:prod": "node -e \"process.env.NODE_ENV='production'; require('./dist/server.js')\"",
    "seed": "node src/scripts/mongo-seed.js",
    "db:indexes": "node src/scripts/mongo-indexes.js",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "cuid": "^2.1.8",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "isomorphic-dompurify": "^3.14.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.2.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "sharp": "^0.33.5",
    "swagger-jsdoc": "^6.2.8",
