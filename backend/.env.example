# =============================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development          # development | production
PORT=3001
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# JWT — User / Agent tokens
# Generate: openssl rand -hex 64
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_strong_random_secret_at_least_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_different_from_JWT_SECRET
JWT_EXPIRES_IN=15m            # access token lifetime  (15m recommended)
JWT_REFRESH_EXPIRES_IN=7d     # refresh token lifetime (7d recommended)

# ---------------------------------------------------------------------------
# JWT — Admin tokens  (MUST be different from user secrets)
# Generate: openssl rand -hex 64
# ---------------------------------------------------------------------------
JWT_ADMIN_SECRET=CHANGE_ME_different_from_JWT_SECRET
JWT_ADMIN_REFRESH_SECRET=CHANGE_ME_different_from_JWT_REFRESH_SECRET
JWT_ADMIN_EXPIRES_IN=15m
JWT_ADMIN_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# CORS
# Development: leave blank to allow http://localhost:*
# Production:  comma-separated list — ALL origins MUST use https://
#              Plain http:// origins are rejected at startup in production.
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=https://admin.beemadiary.com,https://app.beemadiary.com

# ---------------------------------------------------------------------------
# API Base URL  (used in Content-Security-Policy connectSrc)
# Must use https:// in production.
# ---------------------------------------------------------------------------
API_BASE_URL=https://api.beemadiary.com

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/beemadiary
MONGODB_DATABASE=beemadiary
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=

# ---------------------------------------------------------------------------
# Cloudinary  (image uploads)
# ---------------------------------------------------------------------------
USE_CLOUDINARY=true
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------------------------------------------------------------------------
# Admin seed account
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@beemadiary.com
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
ALLOW_SEED_IN_PRODUCTION=false
