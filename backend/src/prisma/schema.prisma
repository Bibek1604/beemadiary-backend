datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum UserType {
  ADMIN
  AGENT
  CLIENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PolicyStatus {
  ACTIVE
  LAPSED
  EXPIRED
  PENDING
}

enum NotificationTargetType {
  SINGLE
  ALL
}

enum TransactionType {
  PREMIUM_PAYMENT
  CLAIM_PAYOUT
  COMMISSION
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model Admin {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique
  email         String    @unique
  phone         String    @unique
  password_hash String
  role          Role      @default(ADMIN)
  status        Status    @default(ACTIVE)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  bulk_notifications BulkNotification[]

  @@map("admins")
}

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  phone_number String    @unique
  image        String
  address      String?
  status       Status    @default(ACTIVE)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  agents      Agent[]
  policies    Policy[]

  @@map("companies")
}

model Agent {
  id            String    @id @default(uuid()) @db.Uuid
  first_name    String
  last_name     String
  email         String    @unique
  phone         String    @unique
  password_hash String
  status        Status    @default(ACTIVE)
  company_id    String?   @db.Uuid
  company       Company?  @relation(fields: [company_id], references: [id], onDelete: SetNull)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  clients              Client[]
  policies             Policy[]
  bulk_notifications   BulkNotification[]

  @@map("agents")
}

model Client {
  id            String    @id @default(uuid()) @db.Uuid
  first_name    String
  last_name     String
  email         String    @unique
  phone         String    @unique
  password_hash String?
  address       String
  status        Status    @default(ACTIVE)
  agent_id      String    @db.Uuid
  agent         Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  policies      Policy[]

  @@map("clients")
}

model Policy {
  id              String       @id @default(uuid()) @db.Uuid
  policy_number   String       @unique
  name            String
  type            String
  coverage_amount Decimal      @db.Decimal(12, 2)
  premium_amount  Decimal      @db.Decimal(12, 2)
  status          PolicyStatus @default(PENDING)
  start_date      DateTime
  end_date        DateTime
  client_id       String       @db.Uuid
  client          Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  agent_id        String       @db.Uuid
  agent           Agent        @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  company_id      String       @db.Uuid
  company         Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  transactions    Transaction[]

  @@map("policies")
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  policy_id        String            @db.Uuid
  policy           Policy            @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  amount           Decimal           @db.Decimal(12, 2)
  type             TransactionType
  payment_method   String
  status           TransactionStatus @default(PENDING)
  transaction_date DateTime          @default(now())
  reference_number String?           @unique
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  deleted_at       DateTime?

  @@map("transactions")
}

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  recipient_id   String    @db.Uuid
  recipient_type UserType
  title          String
  message        String
  is_read        Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("notifications")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  user_type  UserType?
  action     String
  details    Json?
  ip_address String?
  created_at DateTime  @default(now())

  @@map("audit_logs")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  user_type  UserType
  token      String    @unique
  expires_at DateTime
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("sessions")
}

model BulkNotification {
  id              String                 @id @default(uuid()) @db.Uuid
  title           String
  content         String
  target_type     NotificationTargetType
  target_agent_id String?                @db.Uuid
  target_agent    Agent?                 @relation(fields: [target_agent_id], references: [id], onDelete: SetNull)
  created_by      String                 @db.Uuid
  creator         Admin                  @relation(fields: [created_by], references: [id], onDelete: Cascade)
  created_at      DateTime               @default(now())
  updated_at      DateTime               @updatedAt
  deleted_at      DateTime?

  @@index([title])
  @@index([target_type])
  @@index([created_by])
  @@map("bulk_notifications")
}
