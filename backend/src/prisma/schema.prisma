datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum UserType {
  ADMIN
  AGENT
  CLIENT
}

enum Status {
  ACTIVE
  INACTIVE
}

enum PolicyStatus {
  ACTIVE
  LAPSED
  EXPIRED
  PENDING
}

enum NotificationTargetType {
  SINGLE
  ALL
}

enum TransactionType {
  PREMIUM_PAYMENT
  CLAIM_PAYOUT
  COMMISSION
}

enum TransactionStatus {
  PENDING
  SUCCESSFUL
  FAILED
}

model Admin {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique
  email         String    @unique
  phone         String    @unique
  password_hash String
  role          Role      @default(ADMIN)
  status        Status    @default(ACTIVE)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  bulk_notifications BulkNotification[]

  @@map("admins")
}

model Company {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  email        String    @unique
  phone_number String    @unique
  image        String
  address      String?
  status       Status    @default(ACTIVE)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  agents      Agent[]
  policies    Policy[]

  @@map("companies")
}

model Agent {
  id                        String    @id @default(uuid()) @db.Uuid
  agent_code                String?   @unique
  full_name                 String
  email                     String    @unique
  phone_number              String    @unique
  password_hash             String
  lic_agent_code            String?   @unique
  branch_division           String?
  qualification             String?
  position_designation      String?
  short_bio                 String?
  profile_picture           String?
  profile_picture_public_id String?
  status                    Status    @default(ACTIVE)
  company_id                String?   @db.Uuid
  company                   Company?  @relation(fields: [company_id], references: [id], onDelete: SetNull)
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  deleted_at                DateTime?

  clients              Client[]
  policies             Policy[]
  bulk_notifications   BulkNotification[]
  notification_reads   NotificationRead[]
  notes                Note[]
  events               Event[]

  @@map("agents")
}

model Client {
  id            String    @id @default(uuid()) @db.Uuid
  first_name    String
  last_name     String
  email         String    @unique
  phone         String    @unique
  password_hash String?
  address       String
  secondary_phone String?
  dob           DateTime?
  age           Int?
  gender        String?
  nominee_name  String?
  relation_with_nominee String?
  profession    String?
  member_group  String?
  reason_for_insurance String?
  profile_picture String?
  image         String?
  document      String?
  document_2    String?
  documents     Json?
  images        Json?
  additional_documents Json?
  status        Status    @default(ACTIVE)
  agent_id      String    @db.Uuid
  agent         Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  policies      Policy[]
  events        Event[]

  @@map("clients")
}

model Policy {
  id              String       @id @default(uuid())
  policy_number   String       @unique
  name            String
  type            String
  coverage_amount Decimal      @db.Decimal(12, 2)
  premium_amount  Decimal      @db.Decimal(12, 2)
  plan_name       String?
  plan_no         String?
  policy_term     String?
  sum_assured     Decimal?     @db.Decimal(12, 2)
  ab_pwb          String?
  doc             DateTime?
  maturity_time   String?
  discount_scheme String?
  premium_due_date DateTime?
  bank_account_details String?
  branch          String?
  premium_due_paid String?
  premium_status   String?
  policy_status   String?
  status          PolicyStatus @default(PENDING)
  start_date      DateTime
  end_date        DateTime
  client_id       String       @db.Uuid
  client          Client       @relation(fields: [client_id], references: [id], onDelete: Cascade)
  agent_id        String       @db.Uuid
  agent           Agent        @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  company_id      String       @db.Uuid
  company         Company      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  deleted_at      DateTime?

  transactions    Transaction[]

  @@map("policies")
}

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  policy_id        String            @db.Uuid
  policy           Policy            @relation(fields: [policy_id], references: [id], onDelete: Cascade)
  amount           Decimal           @db.Decimal(12, 2)
  type             TransactionType
  payment_method   String
  status           TransactionStatus @default(PENDING)
  transaction_date DateTime          @default(now())
  reference_number String?           @unique
  created_at       DateTime          @default(now())
  updated_at       DateTime          @updatedAt
  deleted_at       DateTime?

  @@map("transactions")
}

model Notification {
  id             String    @id @default(uuid()) @db.Uuid
  recipient_id   String    @db.Uuid
  recipient_type UserType
  title          String
  message        String
  is_read        Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@map("notifications")
}

model AuditLog {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  user_type  UserType?
  action     String
  details    Json?
  ip_address String?
  created_at DateTime  @default(now())

  @@map("audit_logs")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  user_type  UserType
  token      String    @unique
  expires_at DateTime
  ip_address String?
  user_agent String?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@map("sessions")
}

model BulkNotification {
  id              String                 @id @default(uuid()) @db.Uuid
  title           String
  content         String
  target_type     NotificationTargetType
  target_agent_id String?                @db.Uuid
  target_agent    Agent?                 @relation(fields: [target_agent_id], references: [id], onDelete: SetNull)
  created_by      String                 @db.Uuid
  creator         Admin                  @relation(fields: [created_by], references: [id], onDelete: Cascade)
  created_at      DateTime               @default(now())
  updated_at      DateTime               @updatedAt
  deleted_at      DateTime?

  reads           NotificationRead[]

  @@index([title])
  @@index([target_type])
  @@index([created_by])
  @@map("bulk_notifications")
}

model NotificationRead {
  id              String           @id @default(uuid()) @db.Uuid
  notification_id String           @db.Uuid
  notification    BulkNotification @relation(fields: [notification_id], references: [id], onDelete: Cascade)
  agent_id        String           @db.Uuid
  agent           Agent            @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  is_read         Boolean          @default(false)
  read_at         DateTime?
  created_at      DateTime         @default(now())

  @@unique([notification_id, agent_id])
  @@map("notification_reads")
}

enum NoteTag {
  GENERAL
  IMPORTANT
  FOLLOW_UP
  TODO
}

model Note {
  id         String   @id @default(uuid())
  title      String?  @db.VarChar(500) // Auto-generated from content if not provided
  content    String   @db.Text // Required - main note content
  tag        NoteTag  @default(GENERAL) // Tag for categorization
  agent_id   String   @db.Uuid // Agent who created the note
  agent      Agent    @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  deleted_at DateTime? // Soft delete support

  @@index([agent_id])
  @@index([tag])
  @@index([created_at])
  @@map("notes")
}

enum EventType {
  MEETING
  FOLLOW_UP
  RENEWAL
  PREMIUM
  PERSONAL
  OTHER
}

enum RecurrencePattern {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model Event {
  id              String            @id @default(uuid())
  title           String            @db.VarChar(255) // Event title
  description     String?           @db.Text // Event description
  event_type      EventType         @default(OTHER) // Type of event
  event_date      DateTime          // Date of the event
  event_time      String?           // Time in HH:MM format (optional for all-day events)
  is_all_day      Boolean           @default(false) // Whether this is an all-day event
  location        String?           @db.VarChar(500) // Location of the event
  color_label     String?           @default("indigo") // Color category (indigo, pink, rose, green, etc.)

  // Recurrence support
  is_recurring    Boolean           @default(false) // Whether this event repeats
  recurrence_pattern RecurrencePattern? // How the event recurs
  recurrence_end_date DateTime?      // When recurrence stops
  parent_event_id String?           // ID of parent if this is a recurring instance

  // Reminders
  reminder_minutes Int?             // Reminder before event in minutes

  // Ownership
  agent_id        String            @db.Uuid // Agent who created the event
  agent           Agent             @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  // Client association (optional - for client-specific events)
  client_id       String?           @db.Uuid
  client          Client?           @relation(fields: [client_id], references: [id], onDelete: SetNull)

  // Metadata
  created_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt
  deleted_at      DateTime?         // Soft delete support

  @@index([agent_id])
  @@index([event_date])
  @@index([event_type])
  @@index([is_recurring])
  @@index([created_at])
  @@map("events")
}
